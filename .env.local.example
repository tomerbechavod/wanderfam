# ============================================================
# SUPABASE — get from https://app.supabase.com > Project Settings > API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
# On Vercel this becomes: https://wanderfam.vercel.app

# ============================================================
# OPTIONAL INTEGRATIONS — add later for live data
# ============================================================

# Maps — https://console.cloud.google.com (enable Maps JS + Embed APIs)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Weather — https://openweathermap.org/api
NEXT_PUBLIC_OPENWEATHER_KEY=

# Photos — https://unsplash.com/developers
NEXT_PUBLIC_UNSPLASH_KEY=

# ============================================================
# SECURITY — PIN protection for family trips (min 4 digits)
# ============================================================
# Leave blank to disable PIN protection
TRIP_PIN_SECRET=your_random_32char_secret_for_jwt_signing
